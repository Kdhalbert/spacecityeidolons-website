{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "7921391882959662279"
    }
  },
  "parameters": {
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Environment name (dev, staging, prod)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "spacecity",
      "metadata": {
        "description": "Application name prefix"
      }
    },
    "postgresAdminUsername": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator username"
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator password"
      }
    },
    "jwtSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT secret for access tokens"
      }
    },
    "jwtRefreshSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT secret for refresh tokens"
      }
    },
    "githubRepo": {
      "type": "string",
      "metadata": {
        "description": "Your GitHub repository (owner/repo)"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "Environment": "[parameters('environment')]",
        "Application": "SpaceCityEidolons",
        "ManagedBy": "Bicep"
      },
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[uniqueString(resourceGroup().id)]",
    "postgresServerName": "[format('{0}-postgres-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]",
    "appServicePlanName": "[format('{0}-plan-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]",
    "appServiceName": "[format('{0}-api-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]",
    "staticWebAppName": "[format('{0}-web-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]",
    "keyVaultName": "[format('{0}-kv-{1}-{2}', parameters('appName'), parameters('environment'), take(variables('uniqueSuffix'), 8))]",
    "appInsightsName": "[format('{0}-insights-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]",
    "logAnalyticsName": "[format('{0}-logs-{1}-{2}', parameters('appName'), parameters('environment'), variables('uniqueSuffix'))]"
