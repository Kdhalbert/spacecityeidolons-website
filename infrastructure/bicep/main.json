          "serverName": {
            "value": "[variables('postgresServerName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "administratorLogin": {
            "value": "[parameters('postgresAdminUsername')]"
          },
          "administratorPassword": {
            "value": "[parameters('postgresAdminPassword')]"
          },
          "skuName": "[if(equals(parameters('environment'), 'prod'), createObject('value', 'Standard_D2s_v3'), createObject('value', 'Standard_B1ms'))]",
