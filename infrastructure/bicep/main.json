            {
              "condition": "[parameters('enablePublicAccess')]",
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
              "apiVersion": "2023-03-01-preview",
              "name": "[format('{0}/{1}', parameters('serverName'), 'AllowAllAzureServices')]",
              "properties": {
