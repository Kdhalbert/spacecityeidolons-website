# Azure Infrastructure Deployment Parameters (Development)
# Copy this file to main.parameters.dev.json and fill in your values

{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "dev"
    },
    "appName": {
      "value": "spacecity"
    },
    "postgresAdminUsername": {
      "value": "spacecityadmin"
    },
    "postgresAdminPassword": {
      "value": "REPLACE_WITH_SECURE_PASSWORD"
    },
    "jwtSecret": {
      "value": "REPLACE_WITH_JWT_SECRET_MIN_32_CHARS"
    },
    "jwtRefreshSecret": {
      "value": "REPLACE_WITH_JWT_REFRESH_SECRET_MIN_32_CHARS"
    },
    "githubRepo": {
      "value": "yourusername/spacecityeidolons-website-new"
    }
  }
}
